---
import '../../styles/global.css';
import SpeedInsights from "@vercel/speed-insights/astro";
import Analytics from "@vercel/analytics/astro";
---

<html lang="en-US">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
		<link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Resources - The Heart of Tibetan Language</title>
		<meta name="description" content="Books, audio companions, flashcards, and courses to support your Tibetan language learning journey with The Heart of Tibetan Language." />
		<meta name="keywords" content="tibetan language books, tibetan flashcards, anki tibetan, tibetan audio, learn tibetan resources, Heart of Tibetan Language" />

		<!-- Canonical URL -->
		<link rel="canonical" href="https://www.heartoftibetanlanguage.com/resources/" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://www.heartoftibetanlanguage.com/resources/" />
		<meta property="og:title" content="Resources - The Heart of Tibetan Language" />
		<meta property="og:description" content="Books, audio companions, flashcards, and courses to support your Tibetan language learning journey." />
		<meta property="og:image" content="https://www.heartoftibetanlanguage.com/assets/illustrations/Logo-original.png" />

		<!-- Preconnect to Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Cabin:wght@400..700&display=swap" rel="stylesheet">

		<!-- Structured Data -->
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "CollectionPage",
			"name": "Tibetan Learning Resources",
			"description": "Books, audio companions, flashcards, and courses to support your Tibetan language learning journey",
			"url": "https://www.heartoftibetanlanguage.com/resources/"
		}
		</script>

		<!-- BreadcrumbList structured data -->
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "BreadcrumbList",
			"itemListElement": [
				{
					"@type": "ListItem",
					"position": 1,
					"name": "Home",
					"item": "https://www.heartoftibetanlanguage.com/"
				},
				{
					"@type": "ListItem",
					"position": 2,
					"name": "Resources",
					"item": "https://www.heartoftibetanlanguage.com/resources/"
				}
			]
		}
		</script>

		<style>
			.resource-card {
				transition: all 0.3s ease;
			}
			.resource-card:hover {
				transform: translateY(-4px);
				box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
			}
			.card-icon {
				width: 36px;
				height: 36px;
				opacity: 0.7;
			}
			.line-clamp-2 {
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
				.beginner-submenu:hover .beginner-submenu-dropdown {
			opacity: 1;
			visibility: visible;
		}
		.intermediate-submenu:hover .intermediate-submenu-dropdown {
			opacity: 1;
			visibility: visible;
		}
		.advanced-submenu:hover .advanced-submenu-dropdown {
			opacity: 1;
			visibility: visible;
		}
</style>
	</head>
	<body style="background-color: #f9f2e6;">
