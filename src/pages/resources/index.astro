						<img src="/assets/sini-orange.webp" alt="SINI Logo" class="h-32 w-auto" style="display: block;">
					</div>
				</a>

				<!-- Mobile Menu Button -->
				<button id="mobileMenuBtn" class="lg:hidden ml-auto p-2 text-black hover:text-[#CF4D21]" aria-label="Toggle menu">
