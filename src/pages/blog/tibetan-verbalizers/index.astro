				background: linear-gradient(180deg, #FEFBF7 0%, #FFF9F2 100%);
				border: 1px solid rgba(207, 77, 33, 0.12);
				box-shadow: 0 4px 20px rgba(207, 77, 33, 0.06);
				position: relative;
				overflow: hidden;
			}
			.info-card::before {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				height: 3px;
				background: linear-gradient(90deg, #CF4D21 0%, #e85a2c 100%);
				border-radius: 1rem 1rem 0 0;
			}
			/* Vocabulary table */
			.vocab-table {
				width: 100%;
				border-collapse: collapse;
				font-size: 0.95rem;
			}
			.vocab-table th {
				background-color: #CF4D21;
				color: white;
				padding: 10px 14px;
				text-align: left;
				font-family: 'Cabin', Helvetica, Arial, Lucida, sans-serif;
				font-weight: 600;
				font-size: 0.9rem;
			}
			.vocab-table td {
