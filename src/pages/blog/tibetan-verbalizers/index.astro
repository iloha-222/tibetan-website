				border-bottom: 1px solid #e8dccf;
				font-family: 'Cabin', Helvetica, Arial, Lucida, sans-serif;
			}
			.vocab-table tr:nth-child(even) {
				background-color: #f9f2e6;
			}
			.vocab-table tr:hover {
				background-color: #F4E6D6;
			}
			.tibetan-text {
				font-family: "Noto Serif Tibetan", sans-serif;
				font-size: 1.1em;
			}
			/* Table of contents */
			.toc-container {
				background: linear-gradient(180deg, #FFFFFF 0%, #FEFBF7 100%);
				border: 1px solid rgba(207, 77, 33, 0.1);
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
			}
			.toc-item {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				padding: 0.5rem 0;
				transition: all 0.2s ease;
			}
			.toc-item:hover {
				padding-left: 0.25rem;
			}
			.toc-number {
				font-size: 0.9rem;
				font-weight: 600;
				font-family: 'Cabin', Helvetica, Arial, Lucida, sans-serif;
				color: #CF4D21;
				min-width: 1.25rem;
			}
			.toc-link {
				transition: all 0.2s ease;
				font-family: 'Cabin', Helvetica, Arial, Lucida, sans-serif;
				color: #444;
			}
			.toc-link:hover {
				color: #CF4D21;
			}
			/* Example box */
			.example-box {
				background: linear-gradient(180deg, #FFFFFF 0%, #FEFBF7 100%);
				border: 1px solid rgba(207, 77, 33, 0.1);
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
			}
			/* Verbalizer card */
			.verbalizer-card {
				background: linear-gradient(180deg, #FFFFFF 0%, #FEFBF7 100%);
				border: 1px solid rgba(207, 77, 33, 0.12);
				box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04);
			}
			.verbalizer-card h4 {
				font-family: 'Cabin', Helvetica, Arial, Lucida, sans-serif;
				font-size: 1.1rem;
				font-weight: 600;
				color: #1a1a1a;
			}
			.verbalizer-tibetan {
				font-family: "Noto Serif Tibetan", sans-serif;
				font-size: 1.3rem;
				color: #CF4D21;
			}
			/* CTA cards */
			.cta-card {
				background: linear-gradient(180deg, #F4E6D6 0%, #f0dcc8 100%);
				border: 1px solid rgba(207, 77, 33, 0.08);
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
				transition: all 0.4s ease;
			}
			.cta-card:hover {
				transform: translateY(-4px);
				box-shadow: 0 12px 32px rgba(207, 77, 33, 0.12);
			}
			/* FAQ compact styles */
			.faq-item {
				border-bottom: 1px solid #E5E7EB;
			}
			.faq-question {
				cursor: pointer;
			}
			.faq-question h3 {
				font-size: 0.95rem;
				font-weight: 500;
			}
			.faq-answer {
				max-height: 0;
				overflow: hidden;
				transition: max-height 0.3s ease, padding 0.3s ease;
			}
			.faq-answer.active {
				max-height: 500px;
				padding-bottom: 0.75rem;
			}
			.faq-answer p {
				font-size: 0.9rem;
				line-height: 1.6;
				margin-bottom: 0;
			}
			.faq-icon {
				transition: transform 0.3s ease;
			}
			.faq-icon.rotated {
				transform: rotate(180deg);
			}
			/* Section icon in orange rounded square */
			.section-icon-box {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 32px;
				height: 32px;
				background-color: #CF4D21;
				border-radius: 8px;
				flex-shrink: 0;
			}
			.section-icon-box img {
				width: 18px;
				height: 18px;
				filter: brightness(0) invert(1);
			}
			/* Black sheep badge */
			.black-sheep-badge {
				background: linear-gradient(135deg, #333 0%, #555 100%);
				color: white;
				font-size: 0.7rem;
				padding: 2px 8px;
				border-radius: 12px;
				font-family: 'Cabin', Helvetica, Arial, Lucida, sans-serif;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.05em;
