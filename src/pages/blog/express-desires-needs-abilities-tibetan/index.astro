---
import '../../../styles/global.css';
import SpeedInsights from "@vercel/speed-insights/astro";
import Analytics from "@vercel/analytics/astro";

const article = {
	title: "How to Express Desires, Needs, and Abilities in Tibetan: A Complete Guide to Modal Verbs",
	excerpt: "Ever wished you could say \"I want to go to Tibet\" or \"She knows how to write in Tibetan very well\"? Today, we are going to explore modal verbs, which in Tibetan are called བྱ་ཚིག་གཉིས་པ། or \"secondary verbs\" because they always follow the action verb.",
	category: "Grammar",
	readTime: "5 min read",
	date: "February 2026"
};
import Footer from "../../../components/Footer.astro";
