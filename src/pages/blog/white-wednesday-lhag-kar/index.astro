---
import '../../../styles/global.css';
import SpeedInsights from "@vercel/speed-insights/astro";
import Analytics from "@vercel/analytics/astro";

const article = {
	title: "How to Celebrate Lhag-kar: The Significance of \"White Wednesday\" in Tibetan Culture",
	excerpt: "If you have spent any time in Tibetan communities, you may have noticed that on Wednesdays, the streets bloom with the beautiful colors of traditional Chupas. Discover the meaning of Lhag-kar and how you can participate in this weekly celebration of Tibetan identity.",
	category: "Culture",
	readTime: "5 min read",
	date: "February 2026"
};
import Footer from "../../../components/Footer.astro";
