			}
			.toc-item {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				padding: 0.5rem 0;
				transition: all 0.2s ease;
			}
			.toc-item:hover {
				padding-left: 0.25rem;
			}
			.toc-number {
				font-size: 0.9rem;
				font-weight: 600;
				font-family: 'Cabin', Helvetica, Arial, Lucida, sans-serif;
				color: #CF4D21;
				min-width: 1.25rem;
			}
