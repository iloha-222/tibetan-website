				overflow: hidden;
				transition: max-height 0.3s ease, padding 0.3s ease;
			}
			.faq-answer.active {
				max-height: 500px;
				padding-bottom: 0.75rem;
			}
			.faq-answer p {
				font-size: 0.9rem;
				line-height: 1.6;
				margin-bottom: 0;
			}
			.faq-icon {
				transition: transform 0.3s ease;
			}
			.faq-icon.rotated {
				transform: rotate(180deg);
			}
			.section-icon-box {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 32px;
				height: 32px;
				background-color: #CF4D21;
				border-radius: 8px;
				flex-shrink: 0;
			}
			.section-icon-box img {
				width: 18px;
				height: 18px;
				filter: brightness(0) invert(1);
			}
			@media (max-width: 767px) {
				.article-content h2 {
					font-size: 1.25rem !important;
				}
				.article-content h3 {
					font-size: 1rem !important;
				}
