		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Learning to Read - Webinars Only</title>
		<meta name="description" content="Access webinar recordings to learn Tibetan reading and alphabet at your own pace." />

		<!-- Canonical URL -->
		<link rel="canonical" href="https://www.heartoftibetanlanguage.com/self-paced/learning-to-read/webinars-only" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://www.heartoftibetanlanguage.com/self-paced/learning-to-read/webinars-only" />
		<meta property="og:title" content="Learning to Read - Webinars Only" />
