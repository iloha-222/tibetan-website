{
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "heartoftibetanlanguage.com"
        }
      ],
      "destination": "https://www.heartoftibetanlanguage.com/:path",
      "permanent": true
    }
  ]
}